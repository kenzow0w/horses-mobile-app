#!/usr/bin/env sh

# Gradle start up script for UN*X

# Copy of the standard Gradle 8.x wrapper script with minimal adjustments.

APP_BASE_NAME=${0##*/}
APP_HOME=$(CDPATH= cd -- "${0%/*}" > /dev/null && pwd -P)

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS="-Xmx64m -Xms64m"

# Resolve Java command
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        echo "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME" >&2
        echo "Please set the JAVA_HOME variable in your environment to match the location of your Java installation." >&2
        exit 1
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || { echo "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH." >&2; exit 1; }
fi

# Determine OS platform
unameOut="$(uname)"
case "$unameOut" in
    CYGWIN*|MINGW*|MSYS*) msys=true ;;
    *) msys=false ;;
esac

# For Cygwin or MSYS, ensure paths are in UNIX format before anything is touched.
if [ "$msys" = "true" ] ; then
    [ -n "$JAVA_HOME" ] && JAVA_HOME="$(cygpath --unix "$JAVA_HOME")"
    APP_HOME="$(cygpath --unix "$APP_HOME")"
fi

# Set the classpath to the wrapper jar
CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

# Determine the script directory for resolving relative paths
# and execute Gradle wrapper main class
exec "$JAVACMD" \
  $DEFAULT_JVM_OPTS \
  $JAVA_OPTS \
  $GRADLE_OPTS \
  -Dorg.gradle.appname="$APP_BASE_NAME" \
  -classpath "$CLASSPATH" \
  org.gradle.wrapper.GradleWrapperMain "$@"